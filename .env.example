PROJECT_NAME=test-fast-api
ENVIRONMENT=local
SECRET_KEY=change-this-local-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=change-this-admin-password
FIRST_SUPERUSER_EMAIL=admin@example.com
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
SENTRY_DSN=

POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres@pwd
POSTGRES_DB=app

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis@pwd
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=30
REDIS_RETRY_ON_TIMEOUT=true
CACHE_DEFAULT_TTL=604800
LLM_API_BASE_URL=http://127.0.0.1:1104/v1
LLM_API_KEY=107815
LLM_CHAT_MODEL=Qwen3.5-9B-4bit
LLM_CHAT_SESSION_TTL_SECONDS=86400
LLM_CHAT_MAX_HISTORY_MESSAGES=20

DATA_ROOT_DIR=./data
CELERY_BEAT_HEALTHCHECK_INTERVAL_SECONDS=3600
RUNTIME_EXTRA_ENV={}
